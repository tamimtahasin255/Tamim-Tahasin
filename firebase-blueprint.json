{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "User's profile photo URL." },
        "email": { "type": "string", "description": "User's email address." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the user was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "messages": {
      "title": "Chat Message",
      "description": "Stores real-time chat messages.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique message ID." },
        "text": { "type": "string", "description": "Message content." },
        "senderId": { "type": "string", "description": "UID of the sender." },
        "senderName": { "type": "string", "description": "Display name of the sender." },
        "senderPhoto": { "type": "string", "description": "Photo URL of the sender." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the message was sent." }
      },
      "required": ["text", "senderId", "createdAt"]
    },
    "calls": {
      "title": "Call Signaling",
      "description": "Stores signaling data for WebRTC calls.",
      "type": "object",
      "properties": {
        "callerId": { "type": "string", "description": "UID of the caller." },
        "receiverId": { "type": "string", "description": "UID of the receiver." },
        "offer": { "type": "object", "description": "WebRTC offer SDP." },
        "answer": { "type": "object", "description": "WebRTC answer SDP." },
        "status": { "type": "string", "enum": ["calling", "ongoing", "ended"], "description": "Current status of the call." },
        "type": { "type": "string", "enum": ["video", "voice", "screen"], "description": "Type of call." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the call was initiated." }
      },
      "required": ["callerId", "receiverId", "status", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document."
    },
    "/messages/{messageId}": {
      "schema": "messages",
      "description": "Global chat messages."
    },
    "/calls/{callId}": {
      "schema": "calls",
      "description": "Signaling data for a specific call."
    },
    "/calls/{callId}/callerCandidates/{candidateId}": {
      "schema": "object",
      "description": "ICE candidates from the caller."
    },
    "/calls/{callId}/receiverCandidates/{candidateId}": {
      "schema": "object",
      "description": "ICE candidates from the receiver."
    }
  }
}
